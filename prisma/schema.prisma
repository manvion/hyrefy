generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  clerkId       String   @unique
  email         String   @unique
  name          String?
  imageUrl      String?
  country       String?  // ISO 3166-1 alpha-2 (US, CA, GB, DE, IN, AE...)
  language      String?  @default("en") // en, fr, de, etc.
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscription    Subscription?
  resumes         Resume[]
  resumeScans     ResumeScan[]
  applications    JobApplication[]
  interviewPreps  InterviewPrep[]
  roasts          ResumeRoast[]

  @@map("users")
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  status               SubscriptionStatus @default(FREE)
  plan                 PlanTier           @default(FREE)
  scansUsed            Int                @default(0)
  scansLimit           Int                @default(2)
  buildsUsed           Int                @default(0)
  buildsLimit          Int                @default(1)
  coverLettersUsed     Int                @default(0)
  coverLettersLimit    Int                @default(1)
  interviewPrepsUsed   Int                @default(0)
  interviewPrepsLimit  Int                @default(1)
  periodStart          DateTime           @default(now())
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Resume {
  id           String   @id @default(cuid())
  userId       String
  fileName     String
  fileUrl      String
  fileType     String
  rawText      String?  @db.Text
  parsedData   Json?
  isMaster     Boolean  @default(false) // One master resume per user
  targetCountry String? // Country this resume is optimized for
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  scans        ResumeScan[]
  applications JobApplication[]
  roasts       ResumeRoast[]

  @@map("resumes")
}

model ResumeScan {
  id               String     @id @default(cuid())
  userId           String
  resumeId         String?
  jobTitle         String?
  company          String?
  jobDescription   String?    @db.Text
  jobLocation      String?    // "Toronto, CA" or "Remote"
  jobCountry       String?    // ISO code
  atsScore         Int        @default(0)
  keywordScore     Int        @default(0)
  formattingScore  Int        @default(0)
  experienceScore  Int        @default(0)
  recruiterScore   Int        @default(0) // Human readability score
  aiResults        Json?
  suggestions      Json?
  missingKeywords  Json?
  matchedKeywords  Json?
  status           ScanStatus @default(PENDING)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume            Resume?         @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  rewrittenVersions ResumeVersion[]
  application       JobApplication?

  @@map("resume_scans")
}

model ResumeVersion {
  id            String      @id @default(cuid())
  scanId        String
  mode          RewriteMode
  outputLanguage String     @default("en") // en, fr, de...
  targetCountry  String?    // country-optimized version
  originalText  String      @db.Text
  rewrittenText String      @db.Text
  improvements  Json?
  createdAt     DateTime    @default(now())

  scan ResumeScan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@map("resume_versions")
}

model JobApplication {
  id          String            @id @default(cuid())
  userId      String
  company     String
  jobTitle    String
  jobUrl      String?
  jobDescription String?        @db.Text
  location    String?
  salary      String?
  currency    String?           @default("USD")
  status      ApplicationStatus @default(WISHLIST)
  notes       String?           @db.Text
  resumeId    String?
  scanId      String?           @unique
  appliedAt   DateTime?
  interviewAt DateTime?
  offerAt     DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume?     @relation(fields: [resumeId], references: [id])
  scan   ResumeScan? @relation(fields: [scanId], references: [id])

  @@map("job_applications")
}

model InterviewPrep {
  id          String   @id @default(cuid())
  userId      String
  jobTitle    String
  company     String?
  jobDescription String? @db.Text
  questions   Json     // [{question, type, sampleAnswer, tips}]
  industry    String?
  level       String?  // entry, mid, senior, executive
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("interview_preps")
}

model ResumeRoast {
  id          String   @id @default(cuid())
  userId      String
  resumeId    String
  roastText   String   @db.Text  // The brutal honest feedback
  score       Int      // 0-100 (0 = needs complete rewrite, 100 = perfect)
  grade       String   // F, D, C, B, A, S
  issues      Json     // [{category, severity, description, fix}]
  buzzwords   Json     // detected buzzwords
  weakVerbs   Json     // detected weak verbs
  shareToken  String   @unique @default(cuid())
  shareCount  Int      @default(0)
  createdAt   DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("resume_roasts")
}

model UserReport {
  id           String   @id @default(cuid())
  type         String
  title        String
  description  String   @db.Text
  contactPhone String?
  userName     String?
  userEmail    String?
  clerkId      String?
  status       String   @default("new")
  createdAt    DateTime @default(now())

  @@map("user_reports")
}

model RecruiterWaitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  company   String?
  createdAt DateTime @default(now())

  @@map("recruiter_waitlist")
}

enum SubscriptionStatus {
  FREE
  PREMIUM
  CANCELLED
  PAST_DUE
}

enum PlanTier {
  FREE
  PRO_MONTHLY
  PRO_YEARLY
  ENTERPRISE
}

enum ScanStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum RewriteMode {
  PROFESSIONAL
  TECHNICAL
  EXECUTIVE
  STARTUP
  COUNTRY_SPECIFIC
}

enum ApplicationStatus {
  WISHLIST
  APPLIED
  PHONE_SCREEN
  INTERVIEW
  TECHNICAL
  FINAL_ROUND
  OFFER
  REJECTED
  WITHDRAWN
  GHOSTED
}
