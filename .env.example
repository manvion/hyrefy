# ============================================================
# Hyrefy — Environment Variables
# Copy this file to .env.local and fill in real values
# ============================================================

# --- Database (PostgreSQL) ---
# Neon: https://neon.tech  |  Supabase: https://supabase.com  |  Railway: https://railway.app
DATABASE_URL="postgresql://user:password@host:5432/hyrefy?schema=public"

# --- Clerk Authentication ---
# https://dashboard.clerk.com → Create app → API Keys
# In Clerk dashboard: add hyrefy.com, app.hyrefy.com to "Authorized redirect URIs"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_live_..."
CLERK_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# --- Google AI (Gemini 2.0 Flash) ---
# https://aistudio.google.com → Get API Key (free, no credit card)
GOOGLE_AI_API_KEY="AIzaSy..."

# --- Stripe Payments ---
# https://dashboard.stripe.com → Developers → API keys
# Create a "Hyrefy Premium" product + monthly price, copy the price ID
# Webhook endpoint: https://app.hyrefy.com/api/stripe/webhook
STRIPE_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_PREMIUM_PRICE_ID="price_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- App URLs (production) ---
NEXT_PUBLIC_APP_URL="https://app.hyrefy.com"
NEXT_PUBLIC_RECRUITER_URL="https://recruiter.hyrefy.com"

# --- Demo Mode ---
# Set to "false" in production once real Clerk keys are configured
NEXT_PUBLIC_DEMO_MODE="false"

# --- Admin ---
# Change this before going live!
ADMIN_PASSWORD="change-before-going-live"
